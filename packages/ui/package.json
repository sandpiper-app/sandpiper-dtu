{
  "name": "@dtu/ui",
  "version": "0.1.0",
  "type": "module",
  "description": "Shared UI components for DTU twins — Eta partials, Pico CSS, Fastify helpers",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "src/partials/",
    "src/public/"
  ],
  "scripts": {
    "build": "tsc --build",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@fastify/formbody": "^8.0.0",
    "@fastify/static": "^8.0.0",
    "@fastify/view": "^11.0.0",
    "eta": "^3.5.0"
  },
  "devDependencies": {
    "fastify": "^5.0.0",
    "typescript": "^5.7.3"
  }
}
